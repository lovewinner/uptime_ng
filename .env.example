# uptime_ng Environment Variables
# These override config.yaml values

# Server
UPTIME_NG_SERVER_HOST=0.0.0.0
UPTIME_NG_SERVER_PORT=3000

# Database
UPTIME_NG_DATABASE_HOST=localhost
UPTIME_NG_DATABASE_PORT=5432
UPTIME_NG_DATABASE_USER=uptime
UPTIME_NG_DATABASE_PASSWORD=uptime123
UPTIME_NG_DATABASE_DBNAME=uptime_ng
UPTIME_NG_DATABASE_SSLMODE=disable

# JWT
UPTIME_NG_JWT_SECRET=change-me-in-production
UPTIME_NG_JWT_EXPIREHOURS=72

# SMTP (optional)
UPTIME_NG_SMTP_HOST=
UPTIME_NG_SMTP_PORT=587
UPTIME_NG_SMTP_USERNAME=
UPTIME_NG_SMTP_PASSWORD=
UPTIME_NG_SMTP_FROM=

# Feishu (optional)
UPTIME_NG_FEISHU_WEBHOOK_URL=